   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load image (grayscale)\n",
    "image = cv2.imread('Butterfly.jpg', cv2.IMREAD_GRAYSCALE)\n",
    "\n",
    "# Apply Otsu's Thresholding\n",
    "T, thresh_img = cv2.threshold(image, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)\n",
    "\n",
    "# Plot results\n",
    "plt.figure(figsize=(15,5))\n",
    "\n",
    "# 1. Original Image\n",
    "plt.subplot(1,3,1)\n",
    "plt.imshow(image, cmap='gray')\n",
    "plt.title('Original Image')\n",
    "plt.axis('off')\n",
    "\n",
    "# 2. Histogram\n",
    "plt.subplot(1,3,2)\n",
    "plt.hist(image.ravel(), bins=256)\n",
    "plt.axvline(T, color='r', linestyle='--', label=f'T = {T:.2f}')\n",
    "plt.title('Histogram')\n",
    "plt.legend()\n",
    "\n",
    "# 3. Thresholded Image\n",
    "plt.subplot(1,3,3)\n",
    "plt.imshow(thresh_img, cmap='gray')\n",
    "plt.title(\"Otsu's Thresholded Image\")\n",
    "plt.axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Optimal Threshold (Otsu): {T}\")"
   ]
